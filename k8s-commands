 ----------------- helm --------------
 To run any app using helm -> [fast deployment using k8-helm]
 //create a helm of your app
 helm create my_app-helm
 //keep changes in chart and values.yml according to yours req
 repository -> img
 tag -> version[latest]
 port-> your app port
 targetPort ->container Port && also add this in service.yml => targetPort: {{ .Values.service.port }}
 
 //pkg your helm after changes done
 helm pkg my_app-helm
 
 //now install it
 helm install my_app my_app-helm -n my-app --create-namespace
 
  
 
 //to uninstall it
 helm uninstall my_app -n my-app  
 
 ---------- direct from artifactHub ---------
 helm repo add bitnami https://charts.bitnami.com/bitnami  [only once]
 
 //search for your repo and go to install and then 
 helm install my-mongodb bitnami/mongodb --version 18.6.0
 
 //for nginx
 helm install my-nginx bitnami/nginx --version 22.5.0
 or this 
 helm install nginx bitnami/nginx -n nginx --create-namespace
 
